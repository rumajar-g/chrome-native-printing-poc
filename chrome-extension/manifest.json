{
  "manifest_version": 3,
  "name": "Direct Print Bridge",
  "version": "1.0",
  "permissions": ["nativeMessaging", "scripting", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content.js"]
    }
  ]
}